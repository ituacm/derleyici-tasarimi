}

n = 2;
while (n <= 30) {
    d = 2;
    is_prime = 1;
    while (d * d <= n) {
        if (n % d == 0) {
            is_prime = 0;
            break;
        }
        d++;
    }
    if (is_prime == 1)
        print n;
    n++;
}

